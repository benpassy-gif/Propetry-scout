// ── Price drops ───────────────────────────────────────────────────────────────
async function showDrops(env, chatId, msgId) {
  const results = await fetchResults(env);
  const seen = await fetchSeen(env);
  if (!results || !seen) { await sendOrEdit(env, chatId, msgId, "No data yet.", backBtn()); return; }

  const byId = {};
  for (const l of (results.listings || [])) {
    if (!l.id) continue;
    if (!byId[l.id] || l.scraped_at > byId[l.id].scraped_at) byId[l.id] = l;
  }

  const drops = [];
  for (const [id, l] of Object.entries(byId)) {
    const prev = seen[id]?.price || 0;
    if (l.price > 0 && prev > 0 && l.price < prev) {
      drops.push({ ...l, prev_price: prev, drop: prev - l.price, drop_pct: ((prev - l.price) / prev * 100).toFixed(1) });
    }
  }

  if (!drops.length) { await sendOrEdit(env, chatId, msgId, "📉 No price drops detected.", backBtn()); return; }
  drops.sort((a, b) => b.drop_pct - a.drop_pct);

  const kb = { inline_keyboard: [[backBtn2()]] };
  const lines = [`📉 ${drops.length} price drop(s):\n`];
  for (const l of drops.slice(0, 8)) {
    lines.push(`📍 ${l.area} — ${l.title?.slice(0, 40) || "Listing"}`);
    lines.push(`   EUR${fmt(l.prev_price)} → EUR${fmt(l.price)} (-${l.drop_pct}%)`);
    lines.push(`   Score: ${l.deal_score || 0}/7  ${l.url}`);
    lines.push("");
  }
  await sendOrEdit(env, chatId, msgId, lines.join("\n"), kb);
}


// ── Text input handler (called for text during sessions) ──────────────────────
// This runs from the main fetch handler when a session is active
async function handleSessionText(text, chatId, session, env) {
  if (text.toLowerCase() === "/cancel") {
    await clearSession(env, chatId);
    await sendMsg(env, chatId, "Cancelled.");
    await showMainMenu(env, chatId, null);
    return;
  }
  if (session.type === "edit") await handleTextInEditSession(env, chatId, session, text);
  else if (session.type === "new") await handleTextInNewSession(env, chatId, session, text);
  else if (session.type === "analyze") await handleAnalyzeText(env, chatId, session, text);
}


// ── Main entry point ──────────────────────────────────────────────────────────
export default {
  async fetch(request, env) {
    if (request.method !== "POST") return new Response("Property Scout Bot v3", { status: 200 });
    let update;
    try { update = await request.json(); }
    catch { return new Response("Bad request", { status: 400 }); }

    if (update.callback_query) {
      await handleCallback(update.callback_query, env);
      return new Response("OK");
    }

    const message = update.message;
    if (!message || !message.text) return new Response("OK");
    const chatId = String(message.chat.id);
    if (chatId !== ALLOWED_CHAT_ID) return new Response("OK");

    const text = message.text.trim();

    // Check active session first
    const session = await getSession(env, chatId);
    if (session && (session.type === "edit" || session.type === "new" || session.type === "analyze")) {
      await handleSessionText(text, chatId, session, env);
      return new Response("OK");
    }

    // Any other message → show main menu
    await showMainMenu(env, chatId, null);
    return new Response("OK");
  },
};


// ── 🔍 Analyze listing ────────────────────────────────────────────────────────
async function startAnalyze(env, chatId, msgId) {
  const session = { type: "analyze" };
  await saveSession(env, chatId, session);
  const kb = { inline_keyboard: [[{ text: "❌ Cancel", callback_data: "editval:cancel" }]] };
  await sendOrEdit(env, chatId, msgId,
`🔍 Listing Analyzer

Paste the listing URL or send the listing text (title, price, size, area).

I will analyze:
📊 Price vs market
🔧 Renovation & flip ROI
🏠 Long-term rental yield
🏖 Airbnb potential & regulations
📍 Neighborhood profile
📈 Value appreciation potential
✅ Final recommendation`, kb);
}

async function handleAnalyzeText(env, chatId, session, text) {
  if (text.toLowerCase() === "/cancel") {
    await clearSession(env, chatId);
    await sendMsg(env, chatId, "Cancelled.");
    await showMainMenu(env, chatId, null);
    return;
  }

  await clearSession(env, chatId);
  await sendMsg(env, chatId, "⏳ Analyzing listing... this takes ~15 seconds.");

  try {
    const analysis = await analyzeWithClaude(env, text);
    // Send in chunks if too long for Telegram (max 4096 chars)
    const chunks = splitMessage(analysis, 4000);
    for (const chunk of chunks) {
      await sendMsg(env, chatId, chunk);
    }
  } catch (e) {
    await sendMsg(env, chatId, `Analysis failed: ${e.message}`);
  }

  await showMainMenu(env, chatId, null);
}

async function analyzeWithClaude(env, listingText) {
  // Build context from our benchmarks
  const benchmarkContext = Object.entries(AREA_BENCHMARKS)
    .map(([area, b]) => `${area}: EUR${b.price_sqm}/sqm sale, EUR${b.rent_sqm}/sqm/month rent, Airbnb ~EUR${b.airbnb_night}/night, tourist zone: ${b.tourist_zone}`)
    .join("\n");

  const prompt = `You are an expert Greek real estate investment analyst. Analyze this property listing and provide a comprehensive investment report.

LISTING:
${listingText}

ATHENS AREA MARKET DATA (use this for comparison):
${benchmarkContext}

GREEK AIRBNB REGULATIONS (2024-2025):
- Athens tourist zones (Acropolis area, Kolonaki, Monastiraki, Plaka, Psyrri): max 60 days/year for primary residence Airbnb
- Non-tourist zones: max 60 days/year for primary residence; for investment properties a short-term rental license (MITA) is required
- Buildings with multiple units: each unit needs separate MITA license
- New regulation 2024: properties in high-demand areas require registration with AADE tax authority
- Tax: 15-35% on rental income depending on amount

Provide your analysis in Hebrew with the following sections:

**📍 מיקום ושכונה**
- תיאור השכונה וסוג האוכלוסייה
- קרבה לתחבורה ציבורית, מרכזי מסחר, בתי ספר
- רמת הביטחון באזור
- תכניות פיתוח עירוניות ידועות באזור
- פוטנציאל לעליית ערך (1-5 שנים)

**💰 ניתוח מחיר**
- מחיר למ"ר מול ממוצע השוק באזור
- האם המחיר הוגן / מתחת שוק / מעל שוק
- מחיר מטרה לקנייה (אם יש מקום למשא ומתן)

**🔧 פוטנציאל השבחה - Flip**
- עלות שיפוץ משוערת (מינימלי / בינוני / מלא)
- ARV (After Repair Value) - שווי אחרי שיפוץ
- ROI על flip (%)
- האם שווה לעשות flip? ✅/❌

**🏠 השכרה ארוכת טווח**
- שכ"ד חודשי משוער לאחר שיפוץ
- תשואה שנתית ברוטו (%)
- תשואה שנתית נטו אחרי הוצאות (%)
- האם שווה להחזיק להשכרה? ✅/❌

**🏖 פוטנציאל Airbnb**
- מחיר לילה משוער
- תפוסה שנתית משוערת (%)
- הכנסה שנתית ברוטו
- מגבלות רגולטוריות ספציפיות לנכס זה
- האם Airbnb אפשרי וכדאי? ✅/❌

**📊 סיכום וציון**
- ציון עסקה כולל: X/10
- האסטרטגיה המומלצת (flip / השכרה / Airbnb / לא לקנות)
- 3 יתרונות עיקריים
- 3 סיכונים עיקריים
- המלצה סופית: ✅ קנה / ⚠️ בדוק עוד / ❌ עבור הלאה`;

  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": env.ANTHROPIC_API_KEY,
      "anthropic-version": "2023-06-01",
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 2000,
      messages: [{ role: "user", content: prompt }],
    }),
  });

  if (!response.ok) {
    const err = await response.text();
    throw new Error(`Claude API error: ${response.status} - ${err.slice(0, 100)}`);
  }

  const data = await response.json();
  return data.content?.[0]?.text || "No analysis returned.";
}

function splitMessage(text, maxLen) {
  if (text.length <= maxLen) return [text];
  const chunks = [];
  let start = 0;
  while (start < text.length) {
    let end = start + maxLen;
    // Try to cut at a newline
    if (end < text.length) {
      const nl = text.lastIndexOf("\n", end);
      if (nl > start + 100) end = nl;
    }
    chunks.push(text.slice(start, end));
    start = end;
  }
  return chunks;
}


// ── GitHub API ────────────────────────────────────────────────────────────────
async function fetchProfilesRaw(env) {
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/contents/scraper/profiles.json`;
  const resp = await ghFetch(env, url);
  if (!resp.ok) return { profiles: null, raw: null };
  const data = await resp.json();
  const content = atob(data.content.replace(/\n/g, ""));
  const raw = JSON.parse(content);
  raw._sha = data.sha;
  return { profiles: raw.profiles || [], raw };
}
async function fetchProfiles(env) {
  const { profiles } = await fetchProfilesRaw(env);
  return profiles;
}
async function fetchResults(env) {
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/contents/scraper/results.json`;
  const resp = await ghFetch(env, url);
  if (!resp.ok) return null;
  const data = await resp.json();
  return JSON.parse(atob(data.content.replace(/\n/g, "")));
}
async function fetchSeen(env) {
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/contents/scraper/seen_listings.json`;
  const resp = await ghFetch(env, url);
  if (!resp.ok) return {};
  const data = await resp.json();
  return JSON.parse(atob(data.content.replace(/\n/g, "")));
}
async function saveSeen(env, seen) {
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/contents/scraper/seen_listings.json`;
  const getResp = await ghFetch(env, url);
  if (!getResp.ok) return false;
  const current = await getResp.json();
  const encoded = btoa(unescape(encodeURIComponent(JSON.stringify(seen, null, 2))));
  const resp = await ghFetch(env, url, { method: "PUT", body: JSON.stringify({ message: "bot: reset seen", content: encoded, sha: current.sha }) });
  return resp.ok;
}
async function saveProfiles(env, raw) {
  const sha = raw._sha; delete raw._sha;
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/contents/scraper/profiles.json`;
  const encoded = btoa(unescape(encodeURIComponent(JSON.stringify(raw, null, 2))));
  const resp = await ghFetch(env, url, { method: "PUT", body: JSON.stringify({ message: "bot: update profiles", content: encoded, sha }) });
  return resp.ok;
}
async function triggerWorkflow(env, inputs) {
  const url = `https://api.github.com/repos/${env.GITHUB_REPO}/actions/workflows/scout.yml/dispatches`;
  return ghFetch(env, url, { method: "POST", body: JSON.stringify({ ref: "main", inputs }) });
}
async function ghFetch(env, url, opts = {}) {
  return fetch(url, { ...opts, headers: { Authorization: `Bearer ${env.GITHUB_TOKEN}`, Accept: "application/vnd.github+json", "User-Agent": "PropertyScoutBot", "Content-Type": "application/json", ...(opts.headers || {}) } });
}


// ── Telegram ───────────────────────────────────────────────────────────────────
async function sendMsg(env, chatId, text, replyMarkup = null) {
  const body = { chat_id: chatId, text, disable_web_page_preview: true };
  if (replyMarkup) body.reply_markup = replyMarkup;
  await fetch(`https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/sendMessage`, {
    method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
  });
}
async function editMsg(env, chatId, msgId, text, replyMarkup = null) {
  const body = { chat_id: chatId, message_id: msgId, text, disable_web_page_preview: true };
  if (replyMarkup) body.reply_markup = replyMarkup;
  await fetch(`https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/editMessageText`, {
    method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
  });
}
async function sendOrEdit(env, chatId, msgId, text, replyMarkup = null) {
  if (msgId) await editMsg(env, chatId, msgId, text, replyMarkup);
  else await sendMsg(env, chatId, text, replyMarkup);
}
async function answerCallback(env, callbackId) {
  await fetch(`https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/answerCallbackQuery`, {
    method: "POST", headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ callback_query_id: callbackId }),
  });
}


// ── KV Session ─────────────────────────────────────────────────────────────────
async function getSession(env, chatId) {
  if (!env.SESSIONS) return null;
  try { const v = await env.SESSIONS.get(`s:${chatId}`); return v ? JSON.parse(v) : null; }
  catch { return null; }
}
async function saveSession(env, chatId, session) {
  if (!env.SESSIONS) return;
  await env.SESSIONS.put(`s:${chatId}`, JSON.stringify(session), { expirationTtl: 600 });
}
async function clearSession(env, chatId) {
  if (!env.SESSIONS) return;
  await env.SESSIONS.delete(`s:${chatId}`);
}


// ── Utils ──────────────────────────────────────────────────────────────────────
function fmt(n) {
  if (!n && n !== 0) return "?";
  return new Intl.NumberFormat("en-US").format(n);
}
function backBtn() {
  return { inline_keyboard: [[backBtn2()]] };
}
function backBtn2() {
  return { text: "◀️ Main Menu", callback_data: "menu:main" };
}
