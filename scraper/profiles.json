// ── Status ────────────────────────────────────────────────────────────────────
async function showStatus(env, chatId, msgId) {
  const results = await fetchResults(env);
  if (!results) { await sendOrEdit(env, chatId, msgId, "No run data yet.", backBtn()); return; }
  const runs = (results.runs || []).slice(-6).reverse();
  const lines = ["📊 Last Runs:", ""];
  for (const r of runs) {
    const t = new Date(r.timestamp).toLocaleString("he-IL", { timeZone: "Asia/Jerusalem" });
    if (r.error) {
      lines.push(`❌ ${r.profile_name}\n   ${t}\n   ${r.error.slice(0, 50)}`);
    } else {
      let s = `✅ ${r.profile_name}\n   ${t}\n   ${r.fetched} fetched, ${r.new_alerts} alerts`;
      if (r.price_changes) s += `, ${r.price_changes} drops`;
      if (r.auctions) s += `, ${r.auctions} auctions`;
      lines.push(s);
    }
    lines.push("");
  }
  await sendOrEdit(env, chatId, msgId, lines.join("\n"), backBtn());
}


