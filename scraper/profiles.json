// ── Main menu ─────────────────────────────────────────────────────────────────
async function showMainMenu(env, chatId, msgId = null) {
  const keyboard = {
    inline_keyboard: [
      [{ text: "📋 View Profiles", callback_data: "menu:list" }],
      [{ text: "🆕 New Profile",   callback_data: "menu:new"  },
       { text: "✏️ Edit Profile",  callback_data: "menu:edit_pick" }],
      [{ text: "▶️ Run Now",       callback_data: "menu:run_pick" },
       { text: "📊 Status",        callback_data: "menu:status" }],
      [{ text: "🗺 Areas & Prices", callback_data: "menu:areas" },
       { text: "📉 Price Drops",   callback_data: "menu:drops" }],
      [{ text: "👁 Tracked Listings", callback_data: "menu:seen" },
       { text: "🕐 Schedule",      callback_data: "menu:schedule" }],
      [{ text: "🔍 Analyze a Listing", callback_data: "menu:analyze" }],
    ]
  };
  await sendOrEdit(env, chatId, msgId, "🏠 Property Scout — What would you like to do?", keyboard);
}


// ── Callback router ───────────────────────────────────────────────────────────
async function handleCallback(cb, env) {
  const chatId = String(cb.message.chat.id);
  const msgId  = cb.message.message_id;
  const data   = cb.data;

  await answerCallback(env, cb.id);

  // ── Menu actions ──
  if (data === "menu:main")       { await showMainMenu(env, chatId, msgId); return; }
  if (data === "menu:list")       { await showProfileList(env, chatId, msgId); return; }
  if (data === "menu:new")        { await startNew(env, chatId, msgId); return; }
  if (data === "menu:edit_pick")  { await showProfilePicker(env, chatId, msgId, "edit"); return; }
  if (data === "menu:run_pick")   { await showRunPicker(env, chatId, msgId); return; }
  if (data === "menu:status")     { await showStatus(env, chatId, msgId); return; }
  if (data === "menu:areas")      { await showAreas(env, chatId, msgId); return; }
  if (data === "menu:drops")      { await showDrops(env, chatId, msgId); return; }
  if (data === "menu:seen")       { await showSeen(env, chatId, msgId); return; }
  if (data === "menu:seen_reset") { await doSeenReset(env, chatId, msgId); return; }
  if (data === "menu:schedule")   { await showSchedule(env, chatId, msgId); return; }
  if (data === "menu:analyze")    { await startAnalyze(env, chatId, msgId); return; }

  // ── Profile actions ──
  if (data.startsWith("profile:")) {
    const [, action, profileId] = data.split(":");
    if (action === "view")   { await showProfileDetail(env, chatId, msgId, profileId); return; }
    if (action === "edit")   { await startEdit(env, chatId, msgId, profileId); return; }
    if (action === "on")     { await doToggle(env, chatId, msgId, profileId, true); return; }
    if (action === "off")    { await doToggle(env, chatId, msgId, profileId, false); return; }
    if (action === "delete") { await confirmDelete(env, chatId, msgId, profileId); return; }
    if (action === "del_ok") { await doDelete(env, chatId, msgId, profileId); return; }
    if (action === "run")    { await doRun(env, chatId, msgId, profileId); return; }
  }

  // ── Benchmark ──
  if (data.startsWith("bench:")) {
    const area = data.slice(6);
    await showBenchmark(env, chatId, msgId, area);
    return;
  }

  // ── New profile: area selection ──
  if (data.startsWith("newarea:")) {
    await handleNewAreaToggle(env, chatId, msgId, cb, data.slice(8));
    return;
  }
  if (data === "newarea:done") {
    await handleNewAreaDone(env, chatId, msgId);
    return;
  }

  // ── Edit: field value shortcuts ──
  if (data.startsWith("editval:")) {
    await handleEditVal(env, chatId, msgId, data.slice(8));
    return;
  }

  // ── Mode selection (new profile) ──
  if (data.startsWith("mode:")) {
    await handleModeSelect(env, chatId, msgId, data.slice(5));
    return;
  }
}


// ── Profile list ──────────────────────────────────────────────────────────────
async function showProfileList(env, chatId, msgId) {
  const profiles = await fetchProfiles(env);
  if (!profiles) { await sendOrEdit(env, chatId, msgId, "Could not fetch profiles.", backBtn()); return; }
  if (!profiles.length) {
    const kb = { inline_keyboard: [
      [{ text: "🆕 Create first profile", callback_data: "menu:new" }],
      [backBtn2()],
    ]};
    await sendOrEdit(env, chatId, msgId, "No profiles yet.", kb);
    return;
  }

  const rows = profiles.map(p => [{
    text: `${p.active ? "✅" : "⛔"} ${p.name}`,
    callback_data: `profile:view:${p.id}`
  }]);
  rows.push([backBtn2()]);
  await sendOrEdit(env, chatId, msgId, "📋 Your profiles — tap one to manage:", { inline_keyboard: rows });
}


// ── Profile detail ────────────────────────────────────────────────────────────
async function showProfileDetail(env, chatId, msgId, profileId) {
  const profiles = await fetchProfiles(env);
  const p = profiles?.find(x => x.id === profileId);
  if (!p) { await sendOrEdit(env, chatId, msgId, "Profile not found.", backBtn()); return; }

  const f = p.filters || {};
  const status = p.active ? "✅ ACTIVE" : "⛔ INACTIVE";
  const lastRun = p.last_run
    ? new Date(p.last_run).toLocaleString("he-IL", { timeZone: "Asia/Jerusalem" })
    : "Never";

  const text =
`${status} — ${p.name}

📍 Areas: ${(f.areas||[]).join(", ")}
💰 Price: EUR${fmt(f.min_price)}–EUR${fmt(f.max_price)}
📐 Size: ${f.min_sqm}–${f.max_sqm} sqm
📊 Max EUR/sqm: ${fmt(f.max_price_per_sqm)}
🔧 Renovation: EUR${fmt(p.renovation_cost_per_sqm)}/sqm
🎯 Mode: ${p.target_mode || "flip"}
🕐 Last run: ${lastRun}`;

  const toggleBtn = p.active
    ? { text: "⛔ Disable", callback_data: `profile:off:${p.id}` }
    : { text: "✅ Enable",  callback_data: `profile:on:${p.id}` };

  const kb = { inline_keyboard: [
    [{ text: "▶️ Run Now",  callback_data: `profile:run:${p.id}` }],
    [{ text: "✏️ Edit",    callback_data: `profile:edit:${p.id}` },  toggleBtn],
    [{ text: "🗑 Delete",  callback_data: `profile:delete:${p.id}` }],
    [{ text: "◀️ Back to profiles", callback_data: "menu:list" }],
    [backBtn2()],
  ]};

  await sendOrEdit(env, chatId, msgId, text, kb);
}


// ── Profile picker (for edit/run) ─────────────────────────────────────────────
async function showProfilePicker(env, chatId, msgId, action) {
  const profiles = await fetchProfiles(env);
  if (!profiles?.length) { await sendOrEdit(env, chatId, msgId, "No profiles yet.", backBtn()); return; }
  const rows = profiles.map(p => [{
    text: `${p.active ? "✅" : "⛔"} ${p.name}`,
    callback_data: `profile:${action}:${p.id}`
  }]);
  rows.push([backBtn2()]);
  const label = action === "edit" ? "✏️ Pick a profile to edit:" : "▶️ Pick a profile to run:";
  await sendOrEdit(env, chatId, msgId, label, { inline_keyboard: rows });
}

async function showRunPicker(env, chatId, msgId) {
  const profiles = await fetchProfiles(env);
  if (!profiles?.length) { await sendOrEdit(env, chatId, msgId, "No profiles.", backBtn()); return; }
  const rows = profiles.map(p => [{
    text: `${p.active ? "✅" : "⛔"} ${p.name}`,
    callback_data: `profile:run:${p.id}`
  }]);
  rows.push([{ text: "▶️ Run ALL active profiles", callback_data: "profile:run:__all__" }]);
  rows.push([backBtn2()]);
  await sendOrEdit(env, chatId, msgId, "▶️ Which profile to run?", { inline_keyboard: rows });
}


// ── Run ───────────────────────────────────────────────────────────────────────
async function doRun(env, chatId, msgId, profileId) {
  const isAll = profileId === "__all__";
  const resp = await triggerWorkflow(env, { profile_id: isAll ? "" : profileId });
  const target = isAll ? "all active profiles" : `"${profileId}"`;
  if (resp.ok) {
    const kb = { inline_keyboard: [[backBtn2()]] };
    await sendOrEdit(env, chatId, msgId, `▶️ Scout triggered for ${target}.\n\nResults will arrive in ~2 minutes.`, kb);
  } else {
    await sendOrEdit(env, chatId, msgId, `Failed to trigger. Status: ${resp.status}`, backBtn());
  }
}


// ── Toggle ────────────────────────────────────────────────────────────────────
async function doToggle(env, chatId, msgId, profileId, active) {
  const { profiles, raw } = await fetchProfilesRaw(env);
  const profile = profiles?.find(p => p.id === profileId);
  if (!profile) { await sendOrEdit(env, chatId, msgId, "Profile not found.", backBtn()); return; }
  profile.active = active;
  raw.profiles = profiles;
  await saveProfiles(env, raw);
  await showProfileDetail(env, chatId, msgId, profileId);
}


// ── Delete ────────────────────────────────────────────────────────────────────
async function confirmDelete(env, chatId, msgId, profileId) {
  const profiles = await fetchProfiles(env);
  const p = profiles?.find(x => x.id === profileId);
  if (!p) { await sendOrEdit(env, chatId, msgId, "Profile not found.", backBtn()); return; }
  const kb = { inline_keyboard: [
    [{ text: "🗑 Yes, delete it", callback_data: `profile:del_ok:${profileId}` }],
    [{ text: "◀️ Cancel",        callback_data: `profile:view:${profileId}` }],
  ]};
  await sendOrEdit(env, chatId, msgId, `Delete "${p.name}"? This cannot be undone.`, kb);
}

async function doDelete(env, chatId, msgId, profileId) {
  const { profiles, raw } = await fetchProfilesRaw(env);
  const idx = profiles?.findIndex(p => p.id === profileId);
  if (idx === -1 || idx === undefined) { await sendOrEdit(env, chatId, msgId, "Not found.", backBtn()); return; }
  const name = profiles[idx].name;
  profiles.splice(idx, 1);
  raw.profiles = profiles;
  await saveProfiles(env, raw);
  const kb = { inline_keyboard: [[backBtn2()]] };
  await sendOrEdit(env, chatId, msgId, `✅ Profile "${name}" deleted.`, kb);
}


// ── Edit (step by step, text input for numbers) ───────────────────────────────
async function startEdit(env, chatId, msgId, profileId) {
  const profiles = await fetchProfiles(env);
  const profile = profiles?.find(p => p.id === profileId);
  if (!profile) { await sendOrEdit(env, chatId, msgId, "Profile not found.", backBtn()); return; }
  const session = { type: "edit", profileId, step: 0, changes: {}, msgId };
  await saveSession(env, chatId, session);
  await promptEditField(env, chatId, msgId, profile, 0);
}

async function promptEditField(env, chatId, msgId, profile, step) {
  const field = EDIT_FIELDS[step];
  const current = field.inFilters
    ? (profile.filters?.[field.key] ?? "not set")
    : (profile[field.key] ?? "not set");

  const kb = { inline_keyboard: [
    [{ text: "➡️ Keep current value", callback_data: `editval:skip` }],
    [{ text: "❌ Cancel edit",         callback_data: `editval:cancel` }],
  ]};

  await sendOrEdit(env, chatId, msgId,
`✏️ Edit: ${profile.name}
Step ${step + 1}/${EDIT_FIELDS.length}

${field.label}
Current value: ${current}

Type the new value below, or tap a button:`,
  kb);
}

async function handleEditVal(env, chatId, msgId, action) {
  const session = await getSession(env, chatId);
  if (!session || session.type !== "edit") { await showMainMenu(env, chatId, msgId); return; }

  if (action === "cancel") {
    await clearSession(env, chatId);
    await sendOrEdit(env, chatId, msgId, "Edit cancelled.", backBtn());
    return;
  }
  if (action === "skip") {
    await advanceEdit(env, chatId, msgId, session, null);
    return;
  }
}

async function handleTextInEditSession(env, chatId, session, text) {
  const field = EDIT_FIELDS[session.step];
  const parsed = field.type === "int" ? parseInt(text, 10) : parseFloat(text);
  if (isNaN(parsed)) {
    await sendMsg(env, chatId, "Invalid number. Please type a number:");
    return;
  }
  await advanceEdit(env, chatId, null, session, parsed);
}

async function advanceEdit(env, chatId, msgId, session, value) {
  const { profiles, raw } = await fetchProfilesRaw(env);
  const profile = profiles?.find(p => p.id === session.profileId);
  if (!profile) { await clearSession(env, chatId); await showMainMenu(env, chatId, msgId); return; }

  const field = EDIT_FIELDS[session.step];
  if (value !== null) {
    session.changes[field.key] = value;
    if (field.inFilters) { if (!profile.filters) profile.filters = {}; profile.filters[field.key] = value; }
    else { profile[field.key] = value; }
  }

  session.step++;
  if (session.step >= EDIT_FIELDS.length) {
    await clearSession(env, chatId);
    raw.profiles = profiles;
    await saveProfiles(env, raw);
    const changed = Object.keys(session.changes);
    const kb = { inline_keyboard: [[backBtn2()]] };
    if (!changed.length) {
      await sendMsg(env, chatId, "No changes made.");
    } else {
      const lines = [`✅ Profile updated: ${profile.name}`, ""];
      for (const k of changed) {
        const label = EDIT_FIELDS.find(f => f.key === k)?.label || k;
        lines.push(`${label}: ${session.changes[k]}`);
      }
      await sendMsg(env, chatId, lines.join("\n"));
    }
    await showMainMenu(env, chatId, null);
  } else {
    await saveSession(env, chatId, session);
    await promptEditField(env, chatId, null, profile, session.step);
  }
}


// ── New profile ───────────────────────────────────────────────────────────────
async function startNew(env, chatId, msgId) {
  const session = { type: "new", step: 0, data: {}, selectedAreas: [] };
  await saveSession(env, chatId, session);
  await promptNewField(env, chatId, msgId, session);
}

async function promptNewField(env, chatId, msgId, session) {
  const field = NEW_FIELDS[session.step];

  if (field.type === "areas") {
    await showAreaPicker(env, chatId, msgId, session.selectedAreas || []);
    return;
  }

  if (field.type === "mode") {
    const kb = { inline_keyboard: [
      [{ text: "🔄 Flip",  callback_data: "mode:flip" },
       { text: "🏠 Rent",  callback_data: "mode:rent" }],
      [{ text: "❌ Cancel", callback_data: "editval:cancel" }],
    ]};
    await sendOrEdit(env, chatId, msgId,
`🆕 New Profile — Step ${session.step + 1}/${NEW_FIELDS.length}\n\n${field.label}`, kb);
    return;
  }

  const kb = { inline_keyboard: [[{ text: "❌ Cancel", callback_data: "editval:cancel" }]] };
  await sendOrEdit(env, chatId, msgId,
`🆕 New Profile — Step ${session.step + 1}/${NEW_FIELDS.length}\n\n${field.label}`, kb);
}

async function showAreaPicker(env, chatId, msgId, selected) {
  const areas = Object.keys(AREA_BENCHMARKS);
  const rows = [];
  for (let i = 0; i < areas.length; i += 2) {
    const row = [];
    for (let j = i; j < Math.min(i + 2, areas.length); j++) {
      const a = areas[j];
      const isSelected = selected.includes(a);
      row.push({
        text: isSelected ? `✅ ${a}` : a,
        callback_data: `newarea:${a}`
      });
    }
    rows.push(row);
  }
  const doneLabel = selected.length > 0
    ? `✅ Done (${selected.length} selected)`
    : "✅ Done";
  rows.push([{ text: doneLabel, callback_data: "newarea:done" }]);
  rows.push([{ text: "❌ Cancel", callback_data: "editval:cancel" }]);

  await sendOrEdit(env, chatId, msgId,
`🆕 New Profile — Select areas:\n\nSelected: ${selected.length > 0 ? selected.join(", ") : "none"}\n\nTap to toggle:`,
  { inline_keyboard: rows });
}

async function handleNewAreaToggle(env, chatId, msgId, cb, area) {
  const session = await getSession(env, chatId);
  if (!session || session.type !== "new") { await showMainMenu(env, chatId, msgId); return; }

  const idx = session.selectedAreas.indexOf(area);
  if (idx === -1) session.selectedAreas.push(area);
  else session.selectedAreas.splice(idx, 1);

  await saveSession(env, chatId, session);
  await showAreaPicker(env, chatId, msgId, session.selectedAreas);
}

async function handleNewAreaDone(env, chatId, msgId) {
  const session = await getSession(env, chatId);
  if (!session || session.type !== "new") { await showMainMenu(env, chatId, msgId); return; }
  if (!session.selectedAreas.length) {
    await sendMsg(env, chatId, "Please select at least one area.");
    return;
  }
  session.data.areas = session.selectedAreas;
  session.step++;
  await saveSession(env, chatId, session);
  await promptNewField(env, chatId, msgId, session);
}

async function handleModeSelect(env, chatId, msgId, mode) {
  const session = await getSession(env, chatId);
  if (!session) { await showMainMenu(env, chatId, msgId); return; }

  if (session.type === "new") {
    session.data.target_mode = mode;
    session.step++;
    await saveSession(env, chatId, session);

    if (session.step >= NEW_FIELDS.length) {
      await finishNew(env, chatId, msgId, session);
    } else {
      await promptNewField(env, chatId, msgId, session);
    }
  }
}

async function handleTextInNewSession(env, chatId, session, text) {
  const field = NEW_FIELDS[session.step];

  let value;
  if (field.type === "id") {
    value = text.trim().toLowerCase().replace(/\s+/g, "-");
    if (!/^[a-z0-9-]+$/.test(value)) {
      await sendMsg(env, chatId, "❌ ID can only have letters, numbers and dashes. Try again:");
      return;
    }
  } else if (field.type === "str") {
    value = text.trim();
    if (!value) { await sendMsg(env, chatId, "Name cannot be empty. Try again:"); return; }
  } else if (field.type === "int") {
    value = parseInt(text, 10);
    if (isNaN(value)) { await sendMsg(env, chatId, "❌ Not a valid number. Try again:"); return; }
  } else if (field.type === "float") {
    value = parseFloat(text);
    if (isNaN(value)) { await sendMsg(env, chatId, "❌ Not a valid number. Try again:"); return; }
  }

  session.data[field.key] = value;
  session.step++;

  if (session.step >= NEW_FIELDS.length) {
    await finishNew(env, chatId, null, session);
  } else {
    await saveSession(env, chatId, session);
    await promptNewField(env, chatId, null, session);
  }
}

async function finishNew(env, chatId, msgId, session) {
  await clearSession(env, chatId);
  const d = session.data;

  const newProfile = {
    id: d.id,
    name: d.name,
    description: "",
    active: true,
    filters: {
      areas: d.areas,
      min_sqm: d.min_sqm,
      max_sqm: d.max_sqm,
      min_price: d.min_price,
      max_price: d.max_price,
      min_floor: -1,
      max_floor: 10,
      max_price_per_sqm: d.max_price_per_sqm,
      min_deal_score: 4,
    },
    renovation_cost_per_sqm: d.renovation_cost_per_sqm,
    target_mode: d.target_mode,
    created_at: new Date().toISOString(),
    last_run: null,
  };

  const { profiles, raw } = await fetchProfilesRaw(env);
  if (!profiles) { await sendMsg(env, chatId, "Could not save profile."); return; }
  if (profiles.find(p => p.id === newProfile.id)) {
    await sendMsg(env, chatId, `Profile "${newProfile.id}" already exists. Use /edit.`);
    return;
  }

  profiles.push(newProfile);
  raw.profiles = profiles;
  await saveProfiles(env, raw);

  const kb = { inline_keyboard: [
    [{ text: `▶️ Run "${newProfile.name}" now`, callback_data: `profile:run:${newProfile.id}` }],
    [backBtn2()],
  ]};
  await sendMsg(env, chatId,
`✅ Profile created: ${newProfile.name}

📍 Areas: ${newProfile.filters.areas.join(", ")}
💰 EUR${fmt(newProfile.filters.min_price)}–EUR${fmt(newProfile.filters.max_price)}
📐 ${newProfile.filters.min_sqm}–${newProfile.filters.max_sqm} sqm
📊 Max: EUR${fmt(newProfile.filters.max_price_per_sqm)}/sqm
🔧 Renovation: EUR${fmt(newProfile.renovation_cost_per_sqm)}/sqm
🎯 Mode: ${newProfile.target_mode}`);

  await showMainMenu(env, chatId, null);
}


