async function showSchedule(env, chatId, msgId) {
  const now = new Date();
  const next7 = new Date(now); next7.setUTCHours(4, 0, 0, 0);
  if (next7 <= now) next7.setUTCDate(next7.getUTCDate() + 1);
  while (next7.getUTCDay() === 6) next7.setUTCDate(next7.getUTCDate() + 1);
  const next19 = new Date(now); next19.setUTCHours(16, 0, 0, 0);
  if (next19 <= now) next19.setUTCDate(next19.getUTCDate() + 1);
  while (next19.getUTCDay() === 6) next19.setUTCDate(next19.getUTCDate() + 1);

  const kb = { inline_keyboard: [
    [{ text: "▶️ Run now", callback_data: "menu:run_pick" }],
    [backBtn2()],
  ]};
  await sendOrEdit(env, chatId, msgId,
`🕐 Scheduled runs (Israel time):

Morning: 07:00 Sun–Fri
Evening: 19:00 Sun–Fri

Next morning: ${next7.toLocaleString("he-IL", { timeZone: "Asia/Jerusalem" })}
Next evening: ${next19.toLocaleString("he-IL", { timeZone: "Asia/Jerusalem" })}`, kb);
}


